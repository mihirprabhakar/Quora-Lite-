<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit the post</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('includes/nav.ejs') %>
    <h2>Edit the post</h2>

    <form method="post" action="/posts/<%=post.id%>?_method=PATCH">
        <input type="text" placeholder="enter username" name="username" value="<%=post.username%>">
        <br>

        <hr>
    

        <textarea name="content" placeholder="enter the content" cols="30" rows="10"><%=post.content%></textarea>
        <textarea name="img" placeholder="enter the url of the image" cols="30" rows="10"><%=post.img%></textarea>
        <br><hr>
        <button>Submit</button>

    </form>
    <%- include('includes/footer.ejs') %>
</body>
</html>